[run]
# Измеряем покрытие ТОЛЬКО для web/sub (subscription сервис)
source = web/sub

# Исключить из измерения покрытия
omit =
    # Тесты
    web/sub/tests/*
    */tests/*
    */test_*.py
    
    # Конфигурационные файлы
    web/sub/config_dir/*
    web/sub/logger_config.py
    
    # Entry points
    web/sub/main.py
    
    # Python служебные файлы
    */__init__.py
    */__pycache__/*
    web/sub/__pycache__/*
    web/sub/*/__pycache__/*
    web/sub/*/*/__pycache__/*
    
    # Virtual environments
    */.venv/*
    */venv/*
    
    # Pytest cache
    web/sub/.pytest_cache/*

# Использовать относительные пути
relative_files = True

[report]
# Показывать строки которые не покрыты тестами
show_missing = True

# Точность процентов (2 знака после запятой)
precision = 2

# Сортировка по проценту покрытия
sort = Cover

# Пропустить пустые файлы
skip_empty = True

# Исключить из отчёта (игнорируемые строки)
exclude_lines =
    # Стандартные исключения
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    
    # Entry points
    if __name__ == .__main__.:
    
    # Type checking
    if TYPE_CHECKING:
    from typing import TYPE_CHECKING
    
    # Abstract methods
    @abstractmethod
    @abc.abstractmethod
    
    # Логирование (не тестируем логи)
    log_event
    logger\.
    print\(
    
    # Defensive programming
    pass

[html]
# Директория для HTML отчёта
directory = web/sub/htmlcov

[xml]
# Файл для XML отчёта (для CI/CD интеграций)
output = web/sub/coverage.xml
